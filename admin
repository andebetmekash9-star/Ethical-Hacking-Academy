<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>የሊኑክስ ትምህርቶች አስተዳዳሪ</title>
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
</head>
<body>
  <script>
    CMS.init({
      config: {
        backend: { name: "git-gateway", branch: "main" },
        media_folder: "images/uploads",
        public_folder: "/images/uploads",
        collections: [{
          name: "linux_notes",
          label: "የሊኑክስ ትምህርቶች",
          folder: "_posts/linux",
          create: true,
          slug: "{{title}}",
          fields: [
            { label: "አርእስት", name: "title", widget: "string" },
            { label: "የዩቲዩብ ሊንክ", name: "video_url", widget: "string", required: false },
            { label: "ማስታወሻ", name: "body", widget: "markdown" }
          ]
        }]
      }
    });

    // ቀለል ያለ ቅድመ-ዕይታ (ያለ React)
    CMS.registerPreviewTemplate("linux_notes", (entry, widgetFor) => {
      const title = entry.getIn(['data', 'title']);
      const video_url = entry.getIn(['data', 'video_url']);
      const body = widgetFor('body');
      
      let embedUrl = '';
      if (video_url) {
        const match = video_url.match(/^.*(youtu.be\/|v\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/);
        if (match && match[2].length === 11) {
          embedUrl = 'https://www.youtube.com/embed/' + match[2];
        }
      }
      
      return `
        <div style="padding: 20px; font-family: sans-serif; max-width: 800px; margin: 0 auto; color: #fff; background: #1a1a1a;">
          <h1 style="color: #00ff00; border-bottom: 2px solid #00ff00; padding-bottom: 10px;">${title}</h1>
          ${embedUrl ? `
            <div style="margin: 20px 0;">
              <iframe src="${embedUrl}" width="100%" height="315" style="border: none; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,255,0,0.2);" allowfullscreen></iframe>
            </div>
          ` : ''}
          <div style="line-height: 1.6; margin-top: 20px;">${body}</div>
        </div>
      `;
    });
  </script>
</body>
</html>
